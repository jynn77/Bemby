# Admin portal port (host-side)
PORT=3000

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT signing secret -- use a long random string in production
JWT_SECRET=change-me-in-production

# Timezone for the host process (jobs have their own per-job timezone)
TZ=Australia/Sydney

# SQLite database path (set automatically by docker-compose via named volume)
# DB_PATH=/app/data/bemby.db
